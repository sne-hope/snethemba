package com.mycompany.quickchat_1_2;

import java.io.FileWriter;
import java.io.IOException;

public class Message {
    
  
    String messageID;
    int messageNumber;
    String recipient;
    String message;
    String messageHash;

    // Check recipient number
    public static boolean checkRecipientCell(String recipient) {

        // Must start with +27
        if (!recipient.startsWith("+27")) {
            return false;
        }

        // Must be exactly 12 characters
        if (recipient.length() != 12) {
            return false;
        }

        // Check remaining numbers
        String numbers = recipient.substring(3);

        return numbers.matches("\\d+");
    }

    // Generate random message ID
    public static String generateMessageID() {

        String id = "";

        for (int i = 0; i < 10; i++) {
            id += (int)(Math.random() * 10);
        }

        return id;
    }

    // Generate hash
    public static String generateHash(
            String messageID,
            int messageNumber,
            String messageText) {

        String firstTwo =
                messageID.substring(0, 2);

        String[] words =
                messageText.split(" ");

        String firstWord = words[0];
        String lastWord =
                words[words.length - 1];

        return (firstTwo
                + ":"
                + messageNumber
                + ":"
                + firstWord
                + lastWord).toUpperCase();
    }
    // Store message in JSON file
public static void storeMessage(Message msg) {

    try {

        FileWriter file =
                new FileWriter(
                        "messages.json",
                        true
                );

        file.write("{\n");

        file.write("\"Message ID\":\""
                + msg.messageID
                + "\",\n");

        file.write("\"Message Hash\":\""
                + msg.messageHash
                + "\",\n");

        file.write("\"Recipient\":\""
                + msg.recipient
                + "\",\n");

        file.write("\"Message\":\""
                + msg.message
                + "\"\n");

        file.write("}\n");

        file.close();

    } catch (IOException e) {

        System.out.println(
                "Error saving message."
        );
    }
}
}
